      "name": "ERP: Criar Unidades"
    },
    {
      "parameters": {
        "jsCode": "// Pega os dados do CNPJá (primeiro item desse node)\nconst cnpjaData = $('Consulta CNPJá').first().json;\nconst cityNameFromCnpja = cnpjaData?.address?.city || ''; // ex: \"Rio de Janeiro\"\n\n// UF vinda do node \"Codigo Estado\"\nconst ufFromCode = $('Codigo Estado').first().json.stateSigla; // ex: \"RJ\"\n\n// Pega o array de cidades do node anterior (que já filtrou por estado)\nconst citiesArray = $('Código Cidade ERP').all();\n\n// Encontra o numCity correspondente ao nome da cidade\nlet numCity = null;\n\n\nif (cityNameFromCnpja && citiesArray && citiesArray.length > 0) {\n  for (const cityItem of citiesArray) {\n    const cityData = cityItem?.json;\n    if (!cityData || !cityData.nomCity || typeof cityData.nomCity !== 'string') {\n      continue;\n    }\n\n    const cityNameFromApi = cityData.nomCity.trim();\n    const cityNameFromCnpjaClean = cityNameFromCnpja.trim();\n\n    if (cityNameFromApi.toUpperCase() === cityNameFromCnpjaClean.toUpperCase()) {\n      numCity = cityData.numCity;\n      break;\n    }\n  }\n}\n\nif (numCity === null) {\n  console.log('⚠️ Cidade não encontrada:', cityNameFromCnpja);\n  console.log(\n    'Primeiras 5 cidades disponíveis:',\n    citiesArray\n      .slice(0, 5)\n      .map((c) => c.json?.nomCity)\n      .filter(Boolean),\n  );\n}\n\n\n// Define o numCountGroup baseado no estado\nconst numCountGroup = 5716;\n\n// Mapa de CST/CFOP por UF\nconst taxMapByUf = {\n  AL: { cst: 30, cfop: 6258 },\n  AM: { cst: 30, cfop: 6258 },\n  CE: { cst: 30, cfop: 6258 },\n  ES: { cst: 30, cfop: 6258 },\n  MA: { cst: 30, cfop: 6258 },\n  MG: { cst: 30, cfop: 6258 },\n  PA: { cst: 30, cfop: 6258 },\n  PR: { cst: 41, cfop: 6258 },\n  PE: { cst: 30, cfop: 6258 },\n  RJ: { cst: 41, cfop: 5258 },\n  RS: { cst: 30, cfop: 6258 },\n  RO: { cst: 30, cfop: 6258 },\n  SP: { cst: 0, cfop: 5123 },\n};\n\nconst uf = ufFromCode;\n\nlet taxCfg = {};\nif (uf && taxMapByUf[uf]) {\n  taxCfg = taxMapByUf[uf];\n} else {\n  console.log('UF sem mapeamento CST/CFOP:', uf);\n}\n\nconst nomCst = taxCfg.cst ?? null;\nconst nomCfop = taxCfg.cfop ?? null;\n\n// Dados do próprio item (se precisar de algo do $json)\nconst data = $json;\n\n// Flags\nconst indMei = Boolean(data?.simei?.optante) || false;\nconst indSimples = Boolean(data?.simples?.optante) || false;\n\n// Nodes “únicos” também com .first()\nconst extractFile = $('Extract from File1').first().json;\nconst coletaCnpj = $('Coleta CNPJ').first().json;\nconst consulta = $('Consulta CNPJá').first().json;\nconst codigoEstado = $('Codigo Estado').first().json;\n\n// Payload no formato da API ERP\nconst payload = {\n  nomCount: extractFile.CLIENTES,\n  nomCnpj: coletaCnpj.cnpj,\n  nomFull: consulta.company.name,\n  nomAddre: consulta.address.street,\n  nomStateId: $json.nomStateId ? $json.nomStateId : \"ISENTO\",\n  indConsu: true,\n  nomAddreNumbe: consulta.address.number,\n  nomNeigh: consulta.address.district,\n  nomAddreSuppl: consulta.address.details,\n  nomZipCode: consulta.address.zip,\n  indExcepIcms: false,\n  nomIcms: null,\n  nomCfop,\n  nomCst,\n  clienteGestao: true,\n  nomSuframa: null,\n  nomCnpjFatur: null,\n  nomCityId: 'ISENTO',\n  indMei,\n  indSimples,\n  tblCity: {\n    numCity,\n  },\n  tblState: {\n    numState: codigoEstado.stateId,\n  },\n  tblSector: {\n    numSetor: 2,\n  },\n  tblCounterpartyGroup: {\n    numCountGroup,\n  },\n};\n\nconsole.log('✅ Payload gerado com sucesso!');\nconsole.log('Cidade:', cityNameFromCnpja, '→ numCity:', numCity);\nconsole.log('Estado:', ufFromCode, '→ numCountGroup:', numCountGroup);\nconsole.log('CST:', nomCst, '| CFOP:', nomCfop);\n\nreturn { json: payload };\n"
      },
