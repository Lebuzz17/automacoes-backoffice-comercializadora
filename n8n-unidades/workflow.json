        "jsCode": "const headers = $input.first().json.headers;\n\nconst setCookie = headers['set-cookie'];\n\nif (!setCookie) {\n  throw new Error('Header set-cookie não encontrado');\n}\n\nconst cookieHeader = (Array.isArray(setCookie) ? setCookie : [setCookie])\n  .map(c => c.split(';')[0])\n  .join('; ');\n\nreturn [{\n  json: {\n    erpAuthCookie: cookieHeader\n  }\n}];\n"
