    {
      "parameters": {
        "jsCode": "// Dicionário de estados (sigla → ID)\nconst stateMap = {\n  'AC': 1,\n  'AL': 2,\n  'AP': 3,\n  'AM': 4,\n  'BA': 5,\n  'CE': 6,\n  'DF': 7,\n  'ES': 8,\n  'GO': 9,\n  'MA': 10,\n  'MT': 11,\n  'MS': 12,\n  'MG': 13,\n  'PA': 14,\n  'PB': 15,\n  'PR': 16,\n  'PE': 17,\n  'PI': 18,\n  'RJ': 19,\n  'RN': 20,\n  'RS': 21,\n  'RO': 22,\n  'RR': 23,\n  'SC': 24,\n  'SP': 25,\n  'SE': 26,\n  'TO': 27\n};\n\n// Pega o estado do node anterior\nconst stateSigla = $('Consulta CNPJá').item.json.address.state.trim();\n\n// Busca o ID correspondente\nconst stateId = stateMap[stateSigla] ?? -1;\n\n// Retorna o resultado\nreturn {\n  json: {\n    stateId: stateId,\n    stateSigla: stateSigla  // opcional, para debug\n  }\n};"
      },
